# =============================================================================
# Environment Variables — Advanced Hybrid RAG System
# =============================================================================
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real ".env" file to GitHub — it's already excluded
# in .gitignore.
# =============================================================================

# Required: your Groq API key (free, no credit card)
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: which Groq model to use (defaults to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile